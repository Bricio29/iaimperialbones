# =============================================================
#  CONFIGURAÇÃO — IA Imperial Bonés Personalizados (Kommo)
# =============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Kommo CRM ---
# Subdomínio da sua conta (ex: se o painel é imperialbones.kommo.com, use: imperialbones)
KOMMO_SUBDOMAIN=imperialbones

# Token de Longa Duração — gerado em Configurações → Integrações → API → Token
KOMMO_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCI6...

# ID do funil onde os leads serão criados
# Obter em: GET https://{subdomain}.kommo.com/api/v4/leads/pipelines
KOMMO_PIPELINE_ID=100

# ID da etapa inicial dentro do funil (ex: "Novo Lead")
KOMMO_STATUS_ID_NOVO=142

# ID do usuário responsável pelos leads criados pela IA
KOMMO_RESPONSIBLE_USER_ID=5551234

# --- Servidor ---
# URL pública deste servidor (sem barra no final) — necessária para servir imagens dos produtos
# Exemplos: https://iabones.seudominio.com | https://app.imperialbones.com.br
BASE_URL=https://seudominio.com

# Porta do servidor
PORT=3000

# Segredo para validar requisições do webhook (opcional — mesmo valor configurado no Kommo)
WEBHOOK_SECRET=
