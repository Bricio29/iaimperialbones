# =============================================================
#  CONFIGURAÇÃO — IA Imperial Bonés Personalizados (ChatClean)
# =============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- ChatClean ---
# URL autenticada gerada em Configurações → API/Webhook → Adicionar.
# O token JWT já vem embutido como ?token=... — NÃO precisa de header.
CC_PUSH_URL=https://betaapi.chatclean.com.br/v1/api/external/UUID/?token=JWT

# WhatsApp interno que recebe o resumo dos leads qualificados (opcional)
EQUIPE_NUMERO=5584999259527

# --- Servidor ---
# URL pública deste servidor (sem barra no final) — serve as imagens em /assets
# Exemplos: https://ia-imperialbones.SEU-DOMINIO | https://app.imperialbones.com.br
BASE_URL=https://seudominio.com

# Porta do servidor
PORT=3000

# Segredo para validar o webhook de entrada (opcional).
# Cadastrar o MESMO valor no painel ChatClean em "Token de autenticação".
WEBHOOK_SECRET=

# Números permitidos na fase de teste, separados por vírgula (vazio = responde a todos)
# Ex: 5584999259527,5584988887777
IA_ALLOWED_CONTACTS=
